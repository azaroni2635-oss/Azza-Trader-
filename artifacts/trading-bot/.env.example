# ============================================
# TELEGRAM CONFIGURATION
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_admin_user_id_here

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_TIMEOUT_MS=30000
OLLAMA_HEALTH_CHECK_INTERVAL_MS=300000

# ============================================
# TRADING CONFIGURATION
# ============================================
TRADING_PAIR=XAUUSD
FIXED_STOP_LOSS_PIPS=4
MIN_RISK_REWARD_RATIO=2
MIN_CONFIDENCE_SCORE=80
PROFIT_TARGET_RATIO=2

# ============================================
# SESSION CONFIGURATION (UTC)
# ============================================
LONDON_SESSION_OPEN=08:00
LONDON_SESSION_CLOSE=17:00
NEW_YORK_SESSION_OPEN=13:00
NEW_YORK_SESSION_CLOSE=22:00
ENABLED_SESSIONS=london,newyork

# ============================================
# NEWS CONFIGURATION
# ============================================
NEWS_API_KEY=your_news_api_key_here
NEWS_API_URL=https://newsapi.org/v2
HIGH_IMPACT_NEWS_KEYWORDS=inflation,employment,gdp,fed,interest,rate,policy
SKIP_NEWS_CHECK_MINUTES=60

# ============================================
# PRICE DATA CONFIGURATION
# ============================================
PRICE_DATA_SOURCE=mock
PRICE_UPDATE_INTERVAL_MS=60000
PRICE_HISTORY_CANDLES=100

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_PATH=./data/trading.db
DATABASE_BACKUP_INTERVAL_HOURS=24

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE_MB=50
LOG_MAX_FILES=5

# ============================================
# SYSTEM CONFIGURATION
# ============================================
NODE_ENV=production
ENABLE_TRADE_EXECUTION=false
DRY_RUN_MODE=true
MAX_MEMORY_MB=256

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_LIQUIDITY_SWEEP_DETECTION=true
ENABLE_EQUAL_HIGH_LOW_DETECTION=true
ENABLE_SESSION_FILTER=true
ENABLE_NEWS_FILTER=true
ENABLE_CONFIDENCE_SCORING=true
ENABLE_TRADE_JOURNAL=true
ENABLE_HEALTH_CHECK=true
